#!/usr/bin/env bash
# Store your Gmail app password so the monitor can email you when a job finishes.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -x "$HERE/.venv/bin/python" ]; then
  PY="$HERE/.venv/bin/python"
else
  PY="$(command -v python3)"
fi
exec "$PY" "$HERE/set_email.py"
